# ── Backend API URL ──────────────────────────────────────────
# Point this at your running email-remittance-celo server.
# For local dev: http://localhost:3001
# For production: https://your-railway-app.up.railway.app
NEXT_PUBLIC_API_URL=http://localhost:3001

# ── WalletConnect Project ID ──────────────────────────────────
# Required for RainbowKit wallet connect (mobile wallets).
# Free at: https://cloud.walletconnect.com → Create Project → copy Project ID
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your-walletconnect-project-id
